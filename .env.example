# Backend environment variables for Spiritualized AI Mentor
OPENAI_API_KEY=your-openai-api-key
SECRET_KEY=replace-with-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Local PostgreSQL connection string for development
POSTGRES_DSN=postgresql+asyncpg://username:password@localhost:5432/spiritualized
# Railway will usually provide DATABASE_URL or RAILWAY_DATABASE_URL
DATABASE_URL=postgresql://username:password@host:port/spiritualized
RAILWAY_DATABASE_URL=

# Local MongoDB connection string for development
MONGODB_URI=mongodb://localhost:27017/spiritualized
# Railway MongoDB add-on may provide this instead
MONGODB_URL=
RAILWAY_MONGODB_URI=

MONGODB_DB=spiritualized
BACKEND_PORT=8000
# Railway will set PORT automatically in production
PORT=8000
