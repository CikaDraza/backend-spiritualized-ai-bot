# Backend environment variables for Spiritualized AI Mentor.
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit secrets.

APP_ENV=development
APP_NAME=Spiritual English Tutor

FRONTEND_URL=http://localhost:3016
BACKEND_URL=http://localhost:8000

# --- Database ---------------------------------------------------------------
# Production (Railway) injects DATABASE_URL automatically.
DATABASE_URL=postgresql://username:password@host:5432/railway
# Local dev: explicit POSTGRES_DSN takes precedence over DATABASE_URL. Matches
# `docker compose up -d postgres` (Postgres exposed on host port 5455). With this set you can
# run `alembic upgrade head` and `uvicorn app.main:app --reload` without exporting anything.
POSTGRES_DSN=postgresql+asyncpg://spirit:spirit@localhost:5455/spiritualized

# --- Auth -------------------------------------------------------------------
SECRET_KEY=replace-with-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- OpenAI -----------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# --- Upstash Redis (PR5: rate limiting) -------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Email (PR4: Resend; needs custom domain + DNS) -------------------------
RESEND_API_KEY=re_xxx
EMAIL_FROM=Tutor <noreply@yourdomain.com>

# --- Mongo (deferred — "later") ---------------------------------------------
MONGODB_URI=mongodb://localhost:27017/spiritualized
MONGODB_DB=spiritualized
